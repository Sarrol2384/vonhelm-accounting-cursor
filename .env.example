# =============================================================================
# Database — choose ONE option below
# =============================================================================

# --- Option A: Local Docker Postgres (default) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/accounting?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/accounting?schema=public"

# --- Option B: Supabase (recommended — no Docker required) ---
# Get these from: Supabase Dashboard → Project Settings → Database
#
# DATABASE_URL: Session pooler (port 6543) — use for NestJS API at runtime
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# DIRECT_URL: Direct connection (port 5432) — use for Prisma migrations / db push
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# --- Option C: Prisma local dev (no Docker, no Supabase) ---
# Run: pnpm db:local  (starts prisma dev AND syncs DATABASE_URL into .env)
# Then: pnpm db:push && pnpm db:seed && pnpm dev
# Do NOT hand-edit the prisma+postgres URL — re-run pnpm db:sync-env after restarting prisma dev.
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."
# DIRECT_URL="postgres://postgres:postgres@localhost:51215/template1?sslmode=disable&..."

# =============================================================================
# API
# =============================================================================
JWT_SECRET="change-me-in-production-use-long-random-string"
API_PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# =============================================================================
# Supabase (optional — enables Auth + Storage)
# Get from: Supabase Dashboard → Project Settings → API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# JWT Secret from Project Settings → API → JWT Settings (for NestJS token verification)
SUPABASE_JWT_SECRET=""

# Storage bucket name (create in Supabase Dashboard → Storage)
SUPABASE_STORAGE_BUCKET="accounting-files"
