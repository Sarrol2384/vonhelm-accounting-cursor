{
  "name": "@accounting/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "push": "dotenv -e ../../.env -- prisma db push",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "build": "prisma generate && tsc"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
